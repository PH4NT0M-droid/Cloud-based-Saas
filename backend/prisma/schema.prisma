generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(MANAGER)
  permissions      Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  propertyManagers PropertyManager[]
  managerPropertyPermissions ManagerPropertyPermission[]
  createdBookings  Booking[]         @relation("BookingCreator")

  @@map("users")
}

model Property {
  id               String            @id @default(uuid())
  name             String
  location         String
  fullAddress      String            @default("")
  pinCode          String            @default("")
  city             String            @default("")
  state            String            @default("")
  mobileNumber     String?
  landlineNumber   String?
  email            String?
  website          String?
  gstNumber        String?
  propertyLogo     String?
  description      String
  longDescription  String?
  roomTypes        RoomType[]
  bookings         Booking[]
  propertyManagers PropertyManager[]
  managerPropertyPermissions ManagerPropertyPermission[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("properties")
}

model PropertyManager {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("property_managers")
}

model ManagerPropertyPermission {
  id          String   @id @default(uuid())
  managerId   String
  propertyId  String
  permissions Json
  manager     User     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([managerId, propertyId])
  @@index([managerId])
  @@index([propertyId])
  @@map("manager_property_permissions")
}

model RoomType {
  id           String   @id @default(uuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name         String
  maxOccupancy Int
  basePrice        Float @default(0) @map("base_price")
  extraPersonPrice Float @default(0) @map("extra_person_price")
  baseCapacity     Int   @default(1) @map("base_capacity")
  maxCapacity      Int   @default(1) @map("max_capacity")
  baseInventory    Int   @default(1) @map("base_inventory")
  createdAt    DateTime @default(now())
  inventories  Inventory[]
  rates        Rate[]
  ratePlans    RatePlan[]
  roomPricings RoomPricing[]
  bookings     Booking[]
  bookingRooms BookingRoom[]

  @@index([propertyId])
  @@map("room_types")
}

model Inventory {
  id             String   @id @default(uuid())
  roomTypeId     String
  roomType       RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  date           DateTime
  availableRooms Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([roomTypeId, date])
  @@index([date])
  @@map("inventories")
}

model Rate {
  id          String   @id @default(uuid())
  roomTypeId  String
  roomType    RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  date        DateTime
  basePrice   Float
  otaModifier Float    @default(1.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([roomTypeId, date])
  @@index([date])
  @@map("rates")
}

model RatePlan {
  id            String   @id @default(uuid())
  roomTypeId    String
  roomType      RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  mealPlanName  String
  basePrice     Float    @default(0) @map("base_price")
  extraBedPrice Float?
  childPrice    Float?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  roomPricings  RoomPricing[]
  bookings      Booking[]
  bookingRooms  BookingRoom[]

  @@unique([roomTypeId, mealPlanName])
  @@index([roomTypeId])
  @@map("rate_plans")
}

model RoomPricing {
  id         String   @id @default(uuid())
  roomTypeId String
  ratePlanId String
  date       DateTime
  price      Float
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlan   RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([roomTypeId, ratePlanId, date])
  @@index([roomTypeId, date])
  @@index([ratePlanId, date])
  @@map("room_pricings")
}

model Booking {
  id        String        @id @default(uuid())
  otaSource String
  propertyId String?
  property   Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  roomTypeId String
  roomType  RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlanId String?
  ratePlan   RatePlan?    @relation(fields: [ratePlanId], references: [id], onDelete: SetNull)
  guestMobile String?
  guestEmail String?
  gstNumber String?
  guestAddress String?
  guestPincode String?
  guestState String?
  checkIn   DateTime
  checkOut  DateTime
  nights    Int            @default(0)
  totalRooms Int           @default(0)
  guestName String
  guestsCount Int          @default(1) @map("guests_count")
  subtotal   Float         @default(0)
  includeGstInvoice Boolean @default(true)
  gstRate    Float         @default(0)
  cgst       Float         @default(0)
  sgst       Float         @default(0)
  igst       Float         @default(0)
  roundOff   Float         @default(0)
  totalAmount Float        @default(0)
  paidAmount Float         @default(0)
  dueAmount  Float         @default(0)
  paymentReference String?
  specialNote String?
  createdById String?
  createdBy  User?         @relation("BookingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  status    BookingStatus @default(CONFIRMED)
  totalPrice Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  bookingRooms BookingRoom[]

  @@unique([otaSource, roomTypeId, checkIn, guestName])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([ratePlanId])
  @@index([createdById])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model BookingRoom {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomTypeId    String
  roomType      RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  ratePlanId    String?
  ratePlan      RatePlan? @relation(fields: [ratePlanId], references: [id], onDelete: SetNull)
  rooms         Int      @default(1)
  adults        Int      @default(1)
  extraBed      Int      @default(0)
  children      Int      @default(0)
  pricePerNight Float    @default(0)
  totalCost     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([bookingId])
  @@index([roomTypeId])
  @@index([ratePlanId])
  @@map("booking_rooms")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("notifications")
}

model Promotion {
  id              String   @id @default(uuid())
  name            String
  discountPercent Float    @map("discount_percent")
  season          String?
  propertyIds     Json?    @map("property_ids")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("promotions")
}
