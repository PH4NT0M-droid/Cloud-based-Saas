generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(MANAGER)
  permissions      Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  propertyManagers PropertyManager[]

  @@map("users")
}

model Property {
  id               String            @id @default(uuid())
  name             String
  location         String
  description      String
  roomTypes        RoomType[]
  propertyManagers PropertyManager[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("properties")
}

model PropertyManager {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("property_managers")
}

model RoomType {
  id           String   @id @default(uuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name         String
  maxOccupancy Int
  basePrice        Float @default(0) @map("base_price")
  extraPersonPrice Float @default(0) @map("extra_person_price")
  baseCapacity     Int   @default(1) @map("base_capacity")
  maxCapacity      Int   @default(1) @map("max_capacity")
  baseInventory    Int   @default(1) @map("base_inventory")
  createdAt    DateTime @default(now())
  inventories  Inventory[]
  rates        Rate[]
  bookings     Booking[]

  @@index([propertyId])
  @@map("room_types")
}

model Inventory {
  id             String   @id @default(uuid())
  roomTypeId     String
  roomType       RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  date           DateTime
  availableRooms Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([roomTypeId, date])
  @@index([date])
  @@map("inventories")
}

model Rate {
  id          String   @id @default(uuid())
  roomTypeId  String
  roomType    RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  date        DateTime
  basePrice   Float
  otaModifier Float    @default(1.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([roomTypeId, date])
  @@index([date])
  @@map("rates")
}

model Booking {
  id        String        @id @default(uuid())
  otaSource String
  roomTypeId String
  roomType  RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  checkIn   DateTime
  checkOut  DateTime
  guestName String
  guestsCount Int          @default(1) @map("guests_count")
  status    BookingStatus @default(CONFIRMED)
  totalPrice Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([otaSource, roomTypeId, checkIn, guestName])
  @@index([roomTypeId])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("notifications")
}

model Promotion {
  id              String   @id @default(uuid())
  name            String
  discountPercent Float    @map("discount_percent")
  season          String?
  propertyIds     Json?    @map("property_ids")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("promotions")
}
